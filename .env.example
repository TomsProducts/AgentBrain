# Copy to .env and fill in
# CLAUDE_HOME is NOT used in docker-compose.yml (claude-store is a named Docker volume)
# To pre-populate the claude-store volume from your local ~/.claude, see README.md

# Production database credentials (only needed for docker-compose.prod.yml)
DB_USER=agentbrain
DB_PASSWORD=changeme

# Shared secret for sync agent authentication — generate with: openssl rand -hex 32
SYNC_TOKEN=
